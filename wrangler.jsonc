{
    "compatibility_date": "2026-05-31",
    "compatibility_flags": [
        "global_fetch_strictly_public"
    ],
    "workers_dev": true,
    "name": "agentic-healing-desk",
    "main": "@astrojs/cloudflare/entrypoints/server",
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS"
    },
    "routes": [
        {
            "pattern": "agentic-healing.mcpickle.com.au",
            "custom_domain": true,
        },
    ],
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 1,
            "persist": true,
            "invocation_logs": true,
        },
        "traces": {
            "enabled": true,
            "persist": true,
            "head_sampling_rate": 1,
        },
    },
}
