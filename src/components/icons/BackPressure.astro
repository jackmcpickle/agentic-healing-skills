---
import IconBase from '../IconBase.astro';

interface Props {
    class?: string;
}
const { class: className } = Astro.props;
---

<!-- Three arrows pushing left — resistance / back pressure. -->
<IconBase class={className}>
    <path d='M40 14 L12 14'></path>
    <path d='M20 8 L12 14 L20 20'></path>
    <path d='M40 24 L12 24'></path>
    <path d='M20 18 L12 24 L20 30'></path>
    <path d='M40 34 L12 34'></path>
    <path d='M20 28 L12 34 L20 40'></path>
</IconBase>
