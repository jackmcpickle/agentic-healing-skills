---
import '@fontsource-variable/inter';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="h-screen snap-y snap-mandatory overflow-y-scroll scroll-smooth bg-ink font-sans text-canvas-soft">
    <main class="w-full">
      <slot />
    </main>
  </body>
</html>
