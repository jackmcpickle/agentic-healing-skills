---
import '@fontsource-variable/inter';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="bg-ink font-sans text-canvas-soft">
    <main class="h-screen w-full snap-y snap-mandatory overflow-y-scroll scroll-smooth">
      <slot />
    </main>
    <script>
      const main = document.querySelector('main');
      const slides = main ? Array.from(main.querySelectorAll('section')) : [];

      const NEXT = ['ArrowDown', 'ArrowRight', 'PageDown', ' ', 'Spacebar'];
      const PREV = ['ArrowUp', 'ArrowLeft', 'PageUp'];

      function currentIndex() {
        const top = main!.scrollTop;
        let nearest = 0;
        let min = Infinity;
        slides.forEach((s, i) => {
          const d = Math.abs(s.offsetTop - top);
          if (d < min) {
            min = d;
            nearest = i;
          }
        });
        return nearest;
      }

      function go(i: number) {
        const target = slides[Math.max(0, Math.min(slides.length - 1, i))];
        target?.scrollIntoView({ behavior: 'smooth' });
      }

      window.addEventListener('keydown', (e) => {
        if (!main || !slides.length) return;
        const el = document.activeElement;
        if (
          el instanceof HTMLInputElement ||
          el instanceof HTMLTextAreaElement ||
          (el as HTMLElement | null)?.isContentEditable
        )
          return;

        if (NEXT.includes(e.key)) {
          e.preventDefault();
          go(currentIndex() + 1);
        } else if (PREV.includes(e.key)) {
          e.preventDefault();
          go(currentIndex() - 1);
        } else if (e.key === 'Home') {
          e.preventDefault();
          go(0);
        } else if (e.key === 'End') {
          e.preventDefault();
          go(slides.length - 1);
        }
      });
    </script>
  </body>
</html>
