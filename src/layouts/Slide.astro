---
import { nextSlideId } from '../lib/slideCounter';

interface Props {
    /** Section name shown in the slide footer (e.g. "Health Check"). Omit for title/intro slides. */
    section?: string;
    /** Override the auto-generated anchor id. */
    id?: string;
    /** Mark as work-in-progress — shows a DRAFT badge top-right. */
    draft?: boolean;
}
const { section, id, draft = false } = Astro.props;
const slideId = id ?? nextSlideId();
---

<section
    id={slideId}
    class='relative flex min-h-screen w-full snap-start flex-col items-center justify-center gap-8 border-b border-white/5'
>
    {
        draft && (
            <span class='absolute right-12 top-8 rounded-pill bg-warning px-6 py-2.5 text-display-sm font-black uppercase tracking-[0.2em] text-warning-content'>
                Draft
            </span>
        )
    }
    <div class='w-full max-w-6xl px-12 py-20'>
        <slot />
    </div>
    {
        section && (
            <footer class='absolute bottom-8 left-12 text-sm font-semibold uppercase tracking-[0.35em] text-mute'>
                {section}
            </footer>
        )
    }
</section>
