---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Slide from '../layouts/Slide.astro';
import Menu from '../components/Menu.astro';
import Section from '../components/Section.astro';
import Heading from '../components/Heading.astro';
import SubHeading from '../components/SubHeading.astro';
import SubText from '../components/SubText.astro';
import Quote from '../components/Quote.astro';
import QRCode from '../components/QRCode.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Mermaid from '../components/Mermaid.astro';
import Star from '../components/icons/Star.astro';
import Waves from '../components/icons/Waves.astro';
import Replay from '../components/icons/Replay.astro';
import Warning from '../components/icons/Warning.astro';
import BackPressure from '../components/icons/BackPressure.astro';
import Fire from '../components/icons/Fire.astro';
import Triage from '../components/icons/Triage.astro';
import Telemetry from '../components/icons/Telemetry.astro';
import Clock from '../components/icons/Clock.astro';
import Person from '../components/icons/Person.astro';
import Skills from '../components/icons/Skills.astro';
import PullRequest from '../components/icons/PullRequest.astro';
import Bolt from '../components/icons/Bolt.astro';
import Report from '../components/icons/Report.astro';
import Target from '../components/icons/Target.astro';
import Siren from '../components/icons/Siren.astro';
import teeth from '../assets/jacks-check-teeth.png';
import taskManually from '../assets/task-manually.webp';
import { MENU_ITEMS } from '../constants';
import { resetSlideIds } from '../lib/slideCounter';

resetSlideIds(); // restart slide-N numbering at the top of each page render

// Flows rendered to SVG at build time (beautiful-mermaid).
const healthCheckFlow = `flowchart LR
  subgraph Schedule
    direction TB
    A[Code debt]
    B[Wiki debt]
    C[Architecture audit]
    D[Test coverage]
  end
  A --> pr[PR]
  B --> pr
  C --> pr
  D --> pr`;

// Event / Recurring / Human → pipeline, with a review loop, then the merge queue.
const pipelineFlow = `flowchart LR
  E[Event]
  R[Recurring]
  H[Human]
  E --> P[Review Pipeline]
  R --> P
  H --> P
  P --> M[Merge queue]`;

// The hero-demo flow shown in the In-the-Field demo slide.
const demoEventFlow = `flowchart LR
  Events --> Triage --> Discovery --> RCA --> Solution --> Proof`;
const demoReviewFlow = `flowchart LR
    PR[Pull Request]
    A1[Agent Review - 3rd party]
    SR[Security Review]
    TS[Test suite]
    A2[Merge Agent - 1st party]
    PR --> A1
    PR --> SR
    PR --> TS
    SR --> A2
    A1 --> A2
    TS --> A2
    A2 --> M[Merge queue]
`;
---

<Layout title='Agentic Healing in Production'>
    {/* ───────────── INTRO ───────────── */}

    <!-- Title card. -->
    <Slide>
        <Heading
            as='h1'
            size='title'
        >
            Agentic <span class='text-primary'>Healing</span>
            <br />in Production <span class='text-primary'>🩺</span>
        </Heading>
        <SubText>Jack McNicol &bull; Founding Engineer @ SuperIT</SubText>
        <SubHeading variant='muted'>
            Small team building our Sparky agent, FastAPI/React
        </SubHeading>
    </Slide>

    <!-- The dream — the hook. -->
    <Slide>
        <div class='flex flex-col items-start gap-8 text-left'>
            <Star />
            <Heading>The <span class='text-primary'>dream</span></Heading>
            <SubHeading>Autonomously fixing issues at scale.</SubHeading>
        </div>
    </Slide>

    <!-- Dentist story. No title; Jack narrates the ~60s story live. -->
    <Slide>
        <figure class='w-full'>
            <Image
                src={teeth}
                alt=''
                class='mx-auto aspect-square max-h-[80vh] w-auto object-cover rounded-full'
            />
        </figure>
    </Slide>

    <!-- Agenda — the spine flowchart. Health Check lit. -->
    <Slide>
        <Menu active={0} />
    </Slide>

    {/* ───────────── 01 · AGENTIC HEALTH CHECK ───────────── */}
    <Section id={MENU_ITEMS[0].slug}>
        <!-- Flow state. -->
        <Slide section={MENU_ITEMS[0].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Waves />
                <Heading>Flow <span class='text-primary'>state</span></Heading>
                <SubHeading>
                    Update the code so the agent will flow through the code well.
                </SubHeading>
                <SubHeading variant='muted'>
                    What is the new state of the world?
                </SubHeading>
            </div>
        </Slide>

        <!-- Analyse previous sessions. -->
        <Slide section={MENU_ITEMS[0].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Replay />
                <Heading
                    >Read the <span class='text-primary'>sessions</span></Heading
                >
                <SubHeading>
                    Where did it go off track — then find its way back?
                </SubHeading>
                <SubHeading variant='muted'>
                    Show me recommendations to help the agent reach its goal
                    faster. No -&gt; Human review better
                </SubHeading>
            </div>
        </Slide>

        <!-- Back pressure. -->
        <Slide section={MENU_ITEMS[0].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <BackPressure />
                <Heading><span class='text-primary'>Back</span> pressure</Heading
                >
                <SubHeading>Belt and suspenders</SubHeading>
                <SubHeading variant='muted'>
                    PostTool checks, type checks, property, e2e, failure states,
                    not coverage
                </SubHeading>
            </div>
        </Slide>

        <!-- Warnings = errors. -->
        <Slide section={MENU_ITEMS[0].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Warning />
                <Heading
                    >Warnings <span class='text-primary'>=</span> errors</Heading
                >
                <SubHeading>
                    A noisy build teaches the agent that warnings don’t matter.
                </SubHeading>
                <SubHeading variant='muted'>
                    Make every warning fail the build — a clean signal for the
                    agent, and for you.
                </SubHeading>
            </div>
        </Slide>


        <!-- How we use it — scheduled health-check jobs. -->
        <Slide section={MENU_ITEMS[0].name}>
            <div class='flex w-full flex-col items-start gap-8 text-left'>
                <Eyebrow>How we use it</Eyebrow>
                <Mermaid code={healthCheckFlow} />
            </div>
        </Slide>
    </Section>

    <Slide>
        <Menu active={1} />
    </Slide>
    {/* ───────────── 02 · AGENTS IN THE FIELD ───────────── */}
    <Section id={MENU_ITEMS[1].slug}>
        <!-- Section opener image. -->
        <Slide>
            <figure class='w-full'>
                <Image
                    src={taskManually}
                    alt=''
                    class='max-h-[80vh] text-center w-full rounded-xl object-contain'
                />
            </figure>
            <SubHeading class="text-center"
            variant='muted'>Backwards?</SubHeading>
        </Slide>

        <!-- Events, Recurring, Human → Agents. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Heading class="whitespace-pre">Events, Schedules, Humans → Agents</Heading>
                <SubHeading>Managing change.</SubHeading>
            </div>
        </Slide>

        <!-- The pipeline flow. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex w-full flex-col items-start gap-8 text-left'>
                <Mermaid code={pipelineFlow} />
            </div>
        </Slide>

        <!-- Events. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Fire />
                <Heading>Events</Heading>
                <SubHeading>
                    Sentry, Logfire, Linear bug, Slack message
                </SubHeading>
                <SubHeading variant='muted'>
                    Workflows to manage context, investigate, build RCA, RCA to
                    solutions, RCA to proof
                </SubHeading>
            </div>
        </Slide>

        <!-- Discovery: Logfire. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Telemetry />
                <Heading>Event <span class='text-primary'>workflow</span></Heading>
                <SubHeading>
                    The agent’s hypothesis is only as good as the telemetry it
                    has.
                </SubHeading>
                <SubHeading variant='muted'>
                    Triage → Discovery → RCA → Solution → Proof
                </SubHeading>
            </div>
        </Slide>

        <!-- Recurring. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Clock />
                <Heading>Recurring</Heading>
                <SubHeading>
                    Cron-actions. Lowest urgency, widest blast radius.
                </SubHeading>
                <SubHeading variant='muted'>
                    Dependabot, Security scans, Pick up bug ticket. Schedules
                    allow token cost planning.
                </SubHeading>
            </div>
        </Slide>

        <!-- The developer. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Person />
                <Heading>The developer</Heading>
                <SubHeading variant='muted'>
                    Product growth done here, less bug fixing.
                </SubHeading>
            </div>
        </Slide>

        <!-- Review with skills. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Skills />
                <Heading>Review with <span class='text-primary'>skills</span></Heading>
                <SubHeading>
                    A skill is a reusable procedure: input → checklist → output.
                </SubHeading>
                <SubHeading variant='muted'>
                    Cheap deterministic rules first. ast-grep/custom. Once trusted, add to scheduler.
                </SubHeading>
            </div>
        </Slide>

        <!-- PR actions. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <PullRequest />
                <Heading>
                    The PR is the <span class='text-primary'>guardrail</span>
                </Heading>
                <SubHeading>
                    Let agents run wild behind it. Human review? Merge Queues.
                </SubHeading>
                <SubHeading variant='muted'>
                    Greptile · Cursor BugBot · Claude Code Review. Stack
                    reviewers, don’t replace them. Tag a human required
                </SubHeading>
            </div>
        </Slide>

        <!-- Webhooks → RCA. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Bolt />
                <Heading>
                    Heal on <span class='text-primary'>trigger</span></Heading>
                <SubHeading>
                    Production event fires → agent investigates → posts findings
                    in 1–2 minutes.
                </SubHeading>
                <SubHeading variant='muted'>
                    Logfire / PostHog webhook → parallel searcher sub-agents →
                    report in Slack.
                </SubHeading>
            </div>
        </Slide>

        <!-- Hero demo flow. -->
        <Slide section={MENU_ITEMS[1].name}>
            <div class='flex w-full flex-col items-start gap-8 text-left'>
                <Eyebrow>How we use it</Eyebrow>
                <Mermaid code={demoEventFlow} />
                <Mermaid code={demoReviewFlow} />
            </div>
        </Slide>
    </Section>

    <Slide>
        <Menu active={2} />
    </Slide>

    {/* ───────────── 03 · AGENTIC TEST ───────────── */}
    <Section id={MENU_ITEMS[2].slug}>
        <Slide section={MENU_ITEMS[2].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Telemetry />
                <Heading>It's <span class='text-primary'>Fixed!</span> </Heading>
                <SubHeading>
                    Said Claude...
                </SubHeading>
                <SubHeading variant='muted'>
                    Reality: it changed some stuff.
                </SubHeading>
            </div>
        </Slide>
        <!-- The Meijer move. -->
        <Slide section={MENU_ITEMS[2].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Report />
                <Heading>
                    Make it <span class='text-primary'>prove</span> its work
                </Heading>
                <SubHeading>
                    Validating the agent’s work is the bottleneck. Compress it.
                </SubHeading>
                <SubHeading variant='muted'>
                    “Have the agent prove its work in the format that’s <span
                        class='text-primary'>fastest for you to validate</span
                    >.” - A love letter to Pi | Lucas Meijer
                </SubHeading>
            </div>
        </Slide>

        <!-- In practice. -->
    </Section>

    {/* ───────────── 04 · AGENT LEARNINGS / CLOSE ───────────── */}
    <Section id={MENU_ITEMS[3].slug}>
        <!-- The mythos wave. -->
        <Slide section={MENU_ITEMS[3].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Siren />
                <Heading>Are you ready for the mythos wave?</Heading>
                <SubHeading>Time to exploit is now hours.</SubHeading>
            </div>
        </Slide>

        <!-- The warning. -->
        <Slide section={MENU_ITEMS[3].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Warning />
                <Eyebrow>The trap</Eyebrow>
                <Quote>
                    Agents multiply what you already have — foundations or debt.
                </Quote>
                <SubHeading variant='muted'>
                    Skip the foundation and you get the automation confidently making things worse.
                </SubHeading>
            </div>
        </Slide>

        <!-- What's the point? -->
        <Slide section={MENU_ITEMS[3].name}>
            <div class='flex flex-col items-start gap-8 text-left'>
                <Target />
                <Heading
                    >What’s the <span class='text-primary'>point</span>?</Heading
                >
                <SubHeading>
                    Stop doing the work AI is now better at — so you can do the
                    work it can’t.
                </SubHeading>
                <SubHeading variant='muted'>
                    Allows us to move to the important parts. Where should we as
                    engineers be focused?
                </SubHeading>
            </div>
        </Slide>

        <!-- Thanks. -->
        <Slide>
            <div class="flex items-start gap-8">
                <div class="flex-1">
                    <SubHeading>
                        <span class='text-3xl text-primary'>Thanks</span> 🩺
                    </SubHeading>

                    <SubText class='text-3xl'>@jackmcpickle</SubText>
                </div>
                <QRCode class="max-w-xl w-full" />

            </div>
        </Slide>
    </Section>
</Layout>
